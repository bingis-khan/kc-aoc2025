#!/bin/env kkc

al = Alloc.idc()
lines = 'day5'
	File.read-contents(al)
	lines()

Range
	from I64
	to I64

fn mk-range(from, to):
	Range { from, to }

fn parse-range (s)
	sc =& Scan.mk(s)
	from = sc Scan.scan-int() or-fail('from')
	sc drop'(1)
	to = sc Scan.scan-int() or-fail('to')
	return Range { from, to }

ranges = lines
	take-while(fn s: not s null())
	map(parse-range)
println('loaded')

fn in-range(ranges, i): ranges
	any(fn r: r.from <= i and i <= r.to)

