# Part Two: imperative now, don't make it dogshit slow.
fn is-occupied (x I32, y I32)
	if x < 0 or x >= size or y < 0 or y >= size
		return False

	return grid Slice.get(Mem.i32-size(y)) Slice.get(Mem.i32-size(x))

fn count-neighbors (x I32, y I32)
	xx = x - 1
	neighbors = 0
	while xx <= x + 1
		yy = y - 1
		while yy <= y + 1
			if not (xx == x and yy == y) and is-occupied(xx, yy)
				neighbors <= neighbors + 1
			yy <= yy + 1
		xx <= xx + 1

	return neighbors


# part one imperative version is 2 seconds geeeeg
fn remove-paper ()
	smol = 0
	while True
		changed = False

		x = 0
		while x < size
			y = 0
			while y < size
				if is-occupied(x, y)
					neighbors = count-neighbors(x, y)
					if neighbors < 4
						smol <= smol + 1

						# this stuff is part 2 specific
						# part 2 was 28 seconds total, which is bad, but whatever.
						changed <= True
						p = grid Slice.get(Mem.i32-size(y)) Slice.get-ptr(Mem.i32-size(x))
						p <&= False

				y <= y + 1
			x <= x + 1

		if not changed
			return smol

	return unreachable()

remove-paper() println()
