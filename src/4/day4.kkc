#!/bin/env kkc

al = Alloc.idc()


fn is-occupied (grid, x I32, y I32)
	if x < 0 or y < 0
		return False
	else
		return grid drop(Mem.i32-size(y)) map(fn ll: ll drop(Mem.i32-size(x)) head() or-else(False)) head() or-else(False)

grid = 'day4'
	File.read-contents(al)
	lines()
	map(fn line: line map(fn c: c == '@') to-list(al) List.to-slice())
	to-list(al)
	List.to-slice()


size = Mem.size-i32(grid.count)
println('size: \(size)')

fn count-neighbors (x, y): (x - 1) to (x + 1)
	map(fn xx: (y - 1) to (y + 1) filter(fn yy: not (xx == x and yy == y) and grid is-occupied(xx, yy)))
	flatten()
	count()

